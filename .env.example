# Copia este archivo a .env y completa los valores reales.
# .env está en .gitignore y NO se sube al repositorio.

# Contraseña del servidor NUT (nut-server) para la UPS
NUT_API_PASSWORD=cambiame

# Credenciales de la cámara Tapo (cuenta de terceros creada en la app Tapo)
# Se usan en go2rtc.yaml para armar la URL RTSP
TAPO_USER=cambiame
TAPO_PASSWORD=cambiame
