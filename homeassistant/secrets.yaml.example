# Copia este archivo a secrets.yaml y completa los valores reales.
# secrets.yaml está en .gitignore y NO se sube al repositorio.
# https://www.home-assistant.io/docs/configuration/secrets/

some_password: CAMBIAME

# Comando para apagar la UPS vía NUT (incluye la contraseña de nut-server).
# Debe coincidir con NUT_API_PASSWORD del archivo .env
ups_shutdown_command: "docker exec nut-server upscmd -u admin -p TU_PASSWORD_NUT ups shutdown.return"
